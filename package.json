{
  "name": "scaffold-workspace",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "site",
    "editors/vscode"
  ],
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "fallow": "fallow",
    "fallow:ci": "fallow --fail-on-issues",
    "docs:dev": "bun run --cwd site dev",
    "docs:build": "bun run --cwd site build",
    "docs:preview": "bun run --cwd site preview",
    "docs:reference": "bun run --cwd site reference",
    "vscode:compile": "bun run --cwd editors/vscode compile",
    "vscode:compile:all": "bun run --cwd editors/vscode compile:all",
    "vscode:check": "biome check editors/vscode",
    "vscode:lint": "biome lint editors/vscode",
    "vscode:test:web": "bun run --cwd editors/vscode test:web",
    "vscode:test:wasm": "bun run --cwd editors/vscode test:wasm:smoke",
    "vscode:vsix": "bun run --cwd editors/vscode vsix"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "fallow": "^2.93.0"
  }
}
