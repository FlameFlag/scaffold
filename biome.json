{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      ".fallowrc.jsonc",
      "biome.json",
      "package.json",
      "shared/**",
      "site/index.html",
      "site/package.json",
      "site/scripts/**",
      "site/src/**",
      "site/svelte.config.js",
      "site/tsconfig.json",
      "site/vite.config.ts",
      "editors/vscode/language-configuration.json",
      "editors/vscode/package.json",
      "editors/vscode/scripts/**",
      "editors/vscode/snippets/**",
      "editors/vscode/src/**",
      "editors/vscode/syntaxes/**",
      "editors/vscode/tsconfig.json",
      "editors/vscode/tsconfig.scripts.json",
      "editors/vscode/web-test/**",
      "!**/node_modules",
      "!site/.generated",
      "!site/dist",
      "!site/public/reference.static.json",
      "!site/tsconfig.tsbuildinfo",
      "!editors/vscode/.fallow",
      "!editors/vscode/.vscode-test-web",
      "!editors/vscode/out",
      "!editors/vscode/wasm"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.svelte"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
