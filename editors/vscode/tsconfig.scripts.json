{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "outDir": "out/scripts",
    "rootDir": "scripts",
    "strict": true,
    "sourceMap": true,
    "types": ["node"],
    "noEmitOnError": true
