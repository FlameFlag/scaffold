{
  "name": "@scaffold/docs-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "reference": "mkdir -p .generated && cargo run --manifest-path ../Cargo.toml -- docs --format json --output .generated/reference.json",
    "static-reference": "bun scripts/generate-static-reference.mjs",
    "dev": "bun run reference && bun run static-reference && vite --host 127.0.0.1",
    "build": "bun run reference && bun run static-reference && NODE_OPTIONS=--disable-warning=DEP0205 vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "svelte": "^5.56.3",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "marked": "^18.0.5",
    "typescript": "^6.0.3"
  }
}
